{{!--
  Common mechanical effects table. Use on condition, feat, armor, weapon, equipment sheets.
  Params: headerKey, hintKey, showLabel (boolean), changeKeyOptions (object), addButtonKey.
  Context: system (with changes array) from parent.
--}}
<div class="mechanical-effects-section">
    <h3 class="form-header">{{localize headerKey}}</h3>
    <p class="note">{{localize hintKey}}</p>
    <table class="mechanical-effects-table">
        <thead>
            <tr>
                <th>{{localize "THIRDERA.ConditionEffectKey"}}</th>
                <th>{{localize "THIRDERA.ConditionEffectValue"}}</th>
                {{#if showLabel}}
                <th>{{localize "THIRDERA.FeatModifierLabel"}}</th>
                {{/if}}
                <th></th>
            </tr>
        </thead>
        <tbody>
            {{#each system.changes as |change idx|}}
            <tr data-change-index="{{idx}}" class="mechanical-effects-row">
                <td class="mechanical-effects-key-cell">
                    <input type="hidden" name="system.changes.{{idx}}.key" value="{{change.key}}" class="mechanical-effects-key-input" data-change-index="{{idx}}" />
                    <select class="mechanical-effects-field mechanical-effects-key-type" data-change-index="{{idx}}" aria-label="{{localize "THIRDERA.ConditionEffectKey"}}">
                        {{#if ../changeKeyOptions}}{{selectOptions ../changeKeyOptions selected=(skillKeyForSelect change.key)}}{{else}}<option value="">—</option>{{/if}}
                    </select>
                    {{#if (or (eq change.key "skill") (isSkillKey change.key))}}
                    <button type="button" class="mechanical-effects-skill-display" data-action="chooseSkillForModifier" data-change-index="{{idx}}" title="{{localize "THIRDERA.MechanicalEffectsChooseSkill"}}">{{#if (isSkillKey change.key)}}{{skillNameForKey change.key}}{{else}}{{localize "THIRDERA.MechanicalEffectsChooseSkill"}}{{/if}}</button>
                    {{/if}}
                </td>
                <td><input type="number" name="system.changes.{{idx}}.value" value="{{change.value}}" data-dtype="Number" class="mechanical-effects-field" /></td>
                {{#if ../showLabel}}
                <td><input type="text" name="system.changes.{{idx}}.label" value="{{change.label}}" placeholder="{{localize "THIRDERA.FeatModifierLabelPlaceholder"}}" class="mechanical-effects-field" /></td>
                {{/if}}
                <td><button type="button" class="remove-mechanical-effect" data-action="removeMechanicalEffectRow" data-index="{{idx}}" title="{{localize "THIRDERA.Remove"}}"><i class="fas fa-trash"></i></button></td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    <button type="button" class="add-mechanical-effect" data-action="addMechanicalEffectRow"><i class="fas fa-plus"></i> {{localize addButtonKey}}</button>
</div>
