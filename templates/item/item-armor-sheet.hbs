<form class="{{cssClass}} flexcol" autocomplete="off">
    <header class="sheet-header">
        <img class="profile-img" src="{{item.img}}" data-edit="img" data-action="editImage" title="{{item.name}}" />
        <div class="header-fields">
            <h1 class="charname"><input name="name" type="text" value="{{item.name}}"
                    placeholder="Item Name" />{{#unless (eq system.size "Medium")}} <span
                    class="item-size-label">({{system.size}})</span>{{/unless}}</h1>
        </div>
    </header>

    {{!-- Sheet Tab Navigation --}}
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item {{#if (eq tabs.primary 'description')}}active{{/if}}" data-action="changeTab"
            data-group="primary" data-tab="description">Description</a>
        <a class="item {{#if (eq tabs.primary 'details')}}active{{/if}}" data-action="changeTab" data-group="primary"
            data-tab="details">Details</a>
    </nav>

    <section class="sheet-body">
        {{!-- Description Tab --}}
        <div class="tab {{#if (eq tabs.primary 'description')}}active{{/if}}" data-group="primary"
            data-tab="description">
            {{> systems/thirdera/templates/partials/editor-box.hbs
            label="Description"
            name="system.description"
            value=system.description
            enrichedContent=enriched.description
            documentUuid=item.uuid
            }}
        </div>

        {{!-- Details Tab --}}
        <div class="tab details {{#if (eq tabs.primary 'details')}}active{{/if}}" data-group="primary"
            data-tab="details">
            <div class="form-group">
                <label>Armor Type</label>
                <select name="system.armor.type" data-dtype="String">
                    {{selectOptions config.armorTypes selected=system.armor.type localize=true}}
                </select>
            </div>
            <div class="form-group">
                <label>Size</label>
                <select name="system.size" data-dtype="String">
                    {{selectOptions config.sizes selected=system.size}}
                </select>
            </div>
            <div class="form-group">
                <label>Armor Bonus</label>
                <input type="text" name="system.armor.bonus" value="{{system.armor.bonus}}" data-dtype="Number" />
            </div>
            <div class="form-group">
                <label>Max Dex Bonus</label>
                <input type="text" name="system.armor.maxDex" value="{{system.armor.maxDex}}" data-dtype="Number" />
            </div>
            <div class="form-group">
                <label>Check Penalty</label>
                <input type="text" name="system.armor.checkPenalty" value="{{system.armor.checkPenalty}}"
                    data-dtype="Number" />
            </div>
            <div class="form-group">
                <label>Arcane Spell Failure %</label>
                <input type="text" name="system.armor.spellFailure" value="{{system.armor.spellFailure}}"
                    data-dtype="Number" />
            </div>
            <div class="grid grid-2col">
                <div class="form-group">
                    <label>Speed (30ft)</label>
                    <input type="text" name="system.speed.ft30" value="{{system.speed.ft30}}" data-dtype="Number" />
                </div>
                <div class="form-group">
                    <label>Speed (20ft)</label>
                    <input type="text" name="system.speed.ft20" value="{{system.speed.ft20}}" data-dtype="Number" />
                </div>
            </div>
            <div class="grid grid-2col">
                <div class="form-group">
                    <label>Cost (gp)</label>
                    <input type="text" name="system.cost" value="{{system.cost}}" data-dtype="Number" />
                </div>
                <div class="form-group">
                    <label>Weight (lbs)</label>
                    <input type="text" name="system.weight" value="{{system.weight}}" data-dtype="Number" />
                </div>
                <div class="form-group">
                    <label>Quantity</label>
                    <input type="text" name="system.quantity" value="{{system.quantity}}" data-dtype="Number" />
                </div>
            </div>

            <h3 class="form-header">{{localize "THIRDERA.FeatModifiers"}}</h3>
            <p class="note">{{localize "THIRDERA.ItemModifiersHint"}}</p>
            <table class="feat-modifier-changes">
                <thead>
                    <tr>
                        <th>{{localize "THIRDERA.ConditionEffectKey"}}</th>
                        <th>{{localize "THIRDERA.ConditionEffectValue"}}</th>
                        <th>{{localize "THIRDERA.FeatModifierLabel"}}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each system.changes as |change idx|}}
                    <tr data-change-index="{{idx}}">
                        <td>
                            <select name="system.changes.{{idx}}.key">
                                {{#if ../modifierChangeKeys}}{{selectOptions ../modifierChangeKeys selected=change.key}}{{else}}<option value="">—</option>{{/if}}
                            </select>
                        </td>
                        <td><input type="number" name="system.changes.{{idx}}.value" value="{{change.value}}" data-dtype="Number" /></td>
                        <td><input type="text" name="system.changes.{{idx}}.label" value="{{change.label}}" placeholder="{{localize "THIRDERA.FeatModifierLabelPlaceholder"}}" /></td>
                        <td><button type="button" class="remove-feat-modifier" data-action="removeFeatModifierChange" data-index="{{idx}}" title="{{localize "THIRDERA.Remove"}}"><i class="fas fa-trash"></i></button></td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            <button type="button" class="add-feat-modifier" data-action="addFeatModifierChange"><i class="fas fa-plus"></i> {{localize "THIRDERA.FeatAddModifier"}}</button>
        </div>
    </section>
</form>